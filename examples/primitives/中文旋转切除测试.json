              "type": "horizontal_between",
              "first": {
                "type": "point",
                "id": "外圆截面中心点"
              },
              "second": {
                "type": "profile_segment",
                "profile": "外圆旋转截面",
                "index": 0
              },
              "position": [12, 15]
            },
            {
              "id": "外圆中心到底边",
