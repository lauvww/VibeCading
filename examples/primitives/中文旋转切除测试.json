            {
              "id": "中心孔定位点到左边",
              "type": "horizontal_between",
              "first": {
                "type": "point",
                "id": "中心孔截面定位点"
              },
              "second": {
                "type": "profile_segment",
                "profile": "中心孔切除截面",
                "index": 0
              },
              "position": [15, 9]
            },
            {
              "id": "中心孔定位点到底边",
